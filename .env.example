# ============================================================================
# Database
# ============================================================================
# Host port for the docker compose db service. Override if 5432 collides
# with a postgres already running on the host.
DB_PORT=5432
# Postgres connection string. In Docker compose: use 'db' as host. Locally,
# match DB_PORT above.
DATABASE_URL=postgresql://bannerwright:bannerwright@localhost:5432/bannerwright

# ============================================================================
# Auth (single user — credentials baked into env)
# ============================================================================
# Email used to log in.
ADMIN_EMAIL=admin@bannerwright.local
# Argon2id hash. Generate with: pnpm tsx scripts/hash-password.ts <your-password>
ADMIN_PASSWORD_HASH=
# 32+ random chars. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ============================================================================
# AI
# ============================================================================
# Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ============================================================================
# Storage
# ============================================================================
# Adapter: 'local' (MVP) | 's3' (future v2)
STORAGE_DRIVER=local
# Mount root for local FS adapter. In Docker: /app/storage.
STORAGE_PATH=./storage

# ============================================================================
# Limits — runaway-cost protection
# ============================================================================
MAX_GENERATIONS_PER_DAY=100
MAX_LLM_COST_USD_PER_DAY=10

# ============================================================================
# Optional — Sentry (off by default)
# ============================================================================
SENTRY_DSN=

# ============================================================================
# Optional — runtime
# ============================================================================
# 'development' | 'production' | 'test'
NODE_ENV=development
# Pino log level: 'trace'|'debug'|'info'|'warn'|'error'|'fatal'
LOG_LEVEL=info
