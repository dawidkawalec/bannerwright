strict-peer-dependencies=false
auto-install-peers=true
# pnpm 10+ refuses to install when packages have postinstall scripts that haven't
# been explicitly approved. We allowlist the build scripts that matter via the
# `pnpm.onlyBuiltDependencies` field in package.json. This flag prevents the
# `[ERR_PNPM_IGNORED_BUILDS]` failure on packages we don't actually need to
# build (e.g. msw is dev-only).
ignore-scripts=false
